# Example environment variables
# APP_ENV=development

# Gemini LLM API key (required for agents). Use either variable – same key.
# Get it from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GOOGLE_API_KEY=your-gemini-api-key-here   # optional legacy name; same as above

# Firecrawl API key (required for FirecrawlClient)
FIRECRAWL_API_KEY=

# Firebase Authentication configuration
# Absolute or relative path to your Firebase service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Web API key from your Firebase project settings, used for email/password sign up & login.
FIREBASE_API_KEY=